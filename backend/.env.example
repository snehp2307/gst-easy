# GST Easy Backend — Environment Variables

# ─────────────────────────────────────────
# Database (Supabase PostgreSQL)
# ─────────────────────────────────────────
# Get this from: Supabase > Project Settings > Database > Connection String > URI
# Change [YOUR-PASSWORD] to your actual database password
# IMPORTANT: use postgresql+asyncpg:// prefix (NOT postgres://)
DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ─────────────────────────────────────────
# Auth
# ─────────────────────────────────────────
JWT_SECRET=CHANGE-THIS-TO-A-RANDOM-64-CHAR-STRING
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ─────────────────────────────────────────
# CORS (your Vercel frontend URL)
# ─────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","https://your-app.vercel.app"]

# ─────────────────────────────────────────
# Storage (Cloudflare R2)
# ─────────────────────────────────────────
# Get these from: Cloudflare Dashboard > R2 > Manage R2 API Tokens
S3_ENDPOINT_URL=https://YOUR-ACCOUNT-ID.r2.cloudflarestorage.com
S3_ACCESS_KEY=your-r2-access-key
S3_SECRET_KEY=your-r2-secret-key
S3_BUCKET_NAME=gst-bills
S3_REGION=auto

# ─────────────────────────────────────────
# OCR
# ─────────────────────────────────────────
TESSERACT_CMD=tesseract
